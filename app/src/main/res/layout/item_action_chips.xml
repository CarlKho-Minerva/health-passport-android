<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <Button
        android:id="@+id/btn_chip_primary"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:background="@drawable/btn_send_accent"
        android:text="Ask Doctor"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:minWidth="0dp"
        android:minHeight="0dp" />

    <Button
        android:id="@+id/btn_chip_secondary"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:background="@drawable/btn_rounded_border"
        android:text="Save to Vault"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:minWidth="0dp"
        android:minHeight="0dp" />

</LinearLayout>
